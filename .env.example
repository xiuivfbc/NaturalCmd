# ============================================
# 主副模型配置（支持跨厂商）
# ============================================
# 
# 主模型：用于复杂任务（脚本生成）
# - 推荐使用高性能模型（如 GPT-4o、Claude-3.5）
# - 影响用户体验最直接
#
# 副模型：用于简单任务（解释、扩展、技能选择）
# - 推荐使用成本低、速度快的模型（如 GPT-4o-mini、Claude-3-haiku）
# - 可来自不同厂商，独立配置

# ============== 主模型配置 ==============
# 脚本生成使用（推荐：GPT-4o 或更强的模型）

# 模型名称
MODEL_PRIMARY=gpt-4o

# 模型提供商：openai 或 aliyun
MODEL_PRIMARY_PROVIDER=openai

# API Key（OpenAI 格式：sk-...）
MODEL_PRIMARY_KEY=sk-xxx-your-primary-api-key-here

# API Endpoint（可选，如不设置则使用默认值）
MODEL_PRIMARY_ENDPOINT=https://api.openai.com/v1/chat/completions

# ============== 副模型配置 ==============
# 脚本解释、查询扩展、技能选择使用
# （推荐：GPT-4o-mini、Claude-3-haiku 或 qwen-turbo）

# 模型名称
MODEL_SECONDARY=gpt-4o-mini

# 模型提供商：openai 或 aliyun
MODEL_SECONDARY_PROVIDER=openai

# API Key（不同厂商可使用不同的 key）
MODEL_SECONDARY_KEY=sk-xxx-your-secondary-api-key-here

# API Endpoint（可选，如不设置则使用默认值）
MODEL_SECONDARY_ENDPOINT=https://api.openai.com/v1/chat/completions

# ============================================
# 其他配置
# ============================================

# 语言：en 或 zh
LANGUAGE=en

# 是否启用静默模式（不输出提示信息）
SILENT_MODE=false

# 是否启用技能系统
SKILLS_ENABLED=true

# 技能配置文件路径
SKILLS_FILE=locales/skills.json

# 历史记录文件（可选）
HISTORY_FILE=locales/history.json

# 历史记录最大容量
HISTORY_MAX_CAPACITY=50

# 是否启用 RAG（检索增强生成）
RAG_ENABLED=true

# RAG 检索 Top K 结果数量
RAG_TOP_K=3

# RAG 本地最小命中分数
RAG_MIN_LOCAL_HIT_SCORE=4

# RAG 最小本地覆盖率
RAG_MIN_LOCAL_COVERAGE=0.45

# RAG 反馈文件路径（可选）
RAG_FEEDBACK_FILE=locales/feedback.json

# 是否启用 RAG 语义扩展（使用副模型扩展查询）
RAG_SEMANTIC_EXPAND=true

# 是否启用负约束检查
ENABLE_NEGATIVE_CONSTRAINTS=true

# 负约束检查黑名单文件路径（JSON 格式）
# 该文件包含危险操作的关键词和潜在后果
# 用户可以修改此文件以添加/移除危险操作）
BLACKLIST_PATH=locales/safety_blacklist.json



# ============================================
# 跨厂商配置示例
# ============================================
# 
# 示例 1：OpenAI 主模型 + 阿里云副模型（推荐组合）
# 
# MODEL_PRIMARY=gpt-4o
# MODEL_PRIMARY_PROVIDER=openai
# MODEL_PRIMARY_KEY=sk-xxx
# MODEL_PRIMARY_ENDPOINT=https://api.openai.com/v1/chat/completions
# 
# MODEL_SECONDARY=qwen2.5-7b-instruct
# MODEL_SECONDARY_PROVIDER=aliyun
# MODEL_SECONDARY_KEY=sk-xxx-aliyun-key
# MODEL_SECONDARY_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# 
# ============================================
#
# 示例 2：同一厂商不同模型（简单配置）
# 
# MODEL_PRIMARY=gpt-4o
# MODEL_PRIMARY_PROVIDER=openai
# MODEL_PRIMARY_KEY=sk-xxx
# 
# MODEL_SECONDARY=gpt-4o-mini
# MODEL_SECONDARY_PROVIDER=openai
# MODEL_SECONDARY_KEY=sk-xxx  # 可以是同一个 key
# 
# 注意：如果不指定 MODEL_SECONDARY_*，则副模型默认与主模型相同
#
# ============================================
#
# 成本估算（OpenAI 示例）：
# 
# 场景          | 调用频率        | 主模型 gpt-4o | 副模型 gpt-4o-mini | 节省
# --------------|----------------|--------------|-----------------|------
# 命令生成      | 1x/请求        | ✓            | ✗              | -
# 脚本解释      | 1x/请求        | ✗            | ✓              | ~60%
# RAG 扩展      | 0-1x/请求      | ✗            | ✓              | ~90%
# 技能选择      | 0-1x/请求      | ✗            | ✓              | ~90%
#
# 总体成本节省：40-50% 左右
#
